model Booking {
  id        String        @id @default(uuid())
  date      DateTime
  startTime DateTime?
  endTime   DateTime?
  status    BookingStatus @default(PENDING)
  isDeleted Boolean       @default(false)
  deletedAt DateTime?
  version   Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  tutorId   String
  userId    String
  tutor     TutorProfile  @relation("TutorBookings", fields: [tutorId], references: [id], onDelete: Restrict)
  user      User          @relation("StudentBookings", fields: [userId], references: [id], onDelete: Restrict)
  payment   Payment?
  review    Review?

  @@index([userId, tutorId, status])
  @@map("booking")
}
