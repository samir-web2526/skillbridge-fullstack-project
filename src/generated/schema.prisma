model Booking {
  id        String        @id @default(uuid())
  date      DateTime
  startTime DateTime?
  endTime   DateTime?
  status    BookingStatus @default(PENDING)
  isDeleted Boolean       @default(false)
  deletedAt DateTime?
  version   Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  tutorId   String
  userId    String
  tutor     TutorProfile  @relation("TutorBookings", fields: [tutorId], references: [id], onDelete: Restrict)
  user      User          @relation("StudentBookings", fields: [userId], references: [id], onDelete: Restrict)
  payment   Payment?
  review    Review?

  @@index([userId, tutorId, status])
  @@map("booking")
}

model Category {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  tutor       TutorProfile[]

  @@map("category")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REJECTED
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  SSLCOMMERZ
  AMARPAY
  CASH
}

model Payment {
  id              String         @id @default(uuid())
  amount          Decimal        @db.Decimal(10, 2)
  currency        String         @default("BDT")
  status          PaymentStatus  @default(PENDING)
  transactionId   String         @unique
  paymentGateway  String?
  paymentMethod   PaymentMethod?
  gatewayResponse Json?
  bookingId       String         @unique
  booking         Booking        @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  isDeleted       Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([transactionId, status])
  @@map("payment")
}

model Review {
  id        String       @id @default(uuid())
  rating    Int
  comment   String?
  tutorId   String
  bookingId String       @unique
  userId    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  booking   Booking      @relation(fields: [bookingId], references: [id])
  tutor     TutorProfile @relation(fields: [tutorId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@map("review")
}

generator client {
  provider        = "prisma-client-js"
  output          = "../../src/generated"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
}

model TutorProfile {
  id            String    @id @default(uuid())
  bio           String?
  hourlyRate    Decimal   @db.Decimal(10, 2)
  experience    Int
  averageRating Float     @default(0)
  isAvailable   Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  version       Int       @default(0)
  categoryId    String
  userId        String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  category      Category  @relation(fields: [categoryId], references: [id])
  user          User      @relation(fields: [userId], references: [id])
  booking       Booking[] @relation("TutorBookings")
  review        Review[]

  @@index([categoryId, userId])
  @@map("tutor_profile")
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password      String
  emailVerified Boolean       @default(false)
  role          Role          @default(STUDENT)
  image         String?
  phone         String?
  status        UserStatus    @default(ACTIVE)
  isDeleted     Boolean       @default(false)
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tutor         TutorProfile?
  booking       Booking[]     @relation("StudentBookings")
  payment       Payment[]
  review        Review[]

  @@index([email, role])
  @@map("user")
}
